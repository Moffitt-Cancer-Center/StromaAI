# =============================================================================
# StromaAI — Configuration Template
# =============================================================================
# Copy this file to config.env and fill in your site-specific values.
# NEVER commit config.env to version control — it contains secrets.
#
# This file is sourced by systemd units via EnvironmentFile= and by OOD
# script.sh.erb. All StromaAI components read from these variables, so a
# single edit here propagates everywhere.
#
# Usage:
#   cp config/config.example.env /opt/stroma-ai/config.env
#   chmod 640 /opt/stroma-ai/config.env
#   chown stromaai:stromaai /opt/stroma-ai/config.env
# =============================================================================


# =============================================================================
# INSTALLATION DIRECTORY
# =============================================================================
# Override to install to a non-default location (e.g. /opt/stroma-ai-prod).
# The installer patches systemd units at deploy time to use this value.
# Default: /opt/stroma-ai
STROMA_INSTALL_DIR=/opt/stroma-ai


# =============================================================================
# SHARED STORAGE
# =============================================================================

# Absolute path to the root of the shared filesystem visible on BOTH the
# head node (Proxmox VM) and all Slurm GPU worker nodes. Every StromaAI
# component that needs cross-node access (model weights, container image,
# Slurm worker script, job logs) reads files under this root.
#
# All paths below (STROMA_MODEL_PATH, STROMA_CONTAINER, etc.) default to
# subdirectories here. Override any individual path instead if your site
# uses a non-uniform layout.
#
# Examples:
#   /share           (default, simple NFS mounts)
#   /share/hpc_shared  (common at many HPC sites)
#   /mnt/gpfs/cluster  (GPFS/BeeGFS clusters)
#   /lustre/scratch    (Lustre filesystems)
STROMA_SHARED_ROOT=/share


# =============================================================================
# HEAD NODE
# =============================================================================

# Resolvable hostname of the Proxmox VM running Ray head + vLLM.
# Register this in your internal DNS. All Slurm workers and OOD sessions
# connect here. Never use a raw IP — it will break if the VM moves.
STROMA_HEAD_HOST=stroma-ai.your-cluster.example

# Internal HTTP port vLLM listens on (before TLS termination by nginx).
# Users never connect here directly; nginx proxies 443 → this port.
STROMA_VLLM_PORT=8000

# ---------------------------------------------------------------------------
# gloo IPv6 workaround
#
# vLLM 0.7.x always initialises a PyTorch gloo process group, even with
# tensor_parallel_size=1. gloo's TCP device creation calls getifaddrs() and
# tries socket() for each address found. If the first address on the chosen
# interface is IPv6 (e.g. ::1 on lo, or fe80:: link-local), and the kernel
# cannot create AF_INET6 sockets, gloo crashes with:
#   RuntimeError: [enforce fail at gloo/transport/tcp/device.cc:...]
#   Address family not supported by protocol
#
# Fix: set GLOO_SOCKET_IFNAME to your node's primary ethernet/bond interface
# (the one with only IPv4). Detect it with:
#   ip route get 1.1.1.1 | awk '/dev/{for(i=1;i<=NF;i++){if($i=="dev"){print $(i+1); exit}}}'
#
# Do NOT use "lo" — loopback always has ::1 regardless of disable_ipv6.
# ---------------------------------------------------------------------------
# GLOO_SOCKET_IFNAME=bond0

# Internal URL nginx uses to reach vLLM backend (used by gateway → vLLM only; not exposed directly).
# For same-host: http://127.0.0.1:8000
# For remote host: http://vllm-host.example:8000
VLLM_INTERNAL_URL=http://127.0.0.1:8000

# Internal URL nginx uses to reach the OIDC gateway.
# The gateway validates JWTs and forwards to vLLM with the internal API key.
# Must match GATEWAY_PORT below. Change only if running gateway on a separate host.
GATEWAY_INTERNAL_URL=http://127.0.0.1:9000

# External HTTPS port exposed by nginx (what users and OOD connect to).
STROMA_HTTPS_PORT=443

# Ray GCS port. Use 6380, not 6379 (6379 conflicts with Redis on many nodes).
STROMA_RAY_PORT=6380

# Override for containerised deployments where the Ray head runs as a
# separate service under a different hostname (e.g. "ray-head" in a Compose
# stack). For bare-metal and VM deployments this defaults to STROMA_HEAD_HOST
# so no change is needed. Uncomment and set only for compose/container setups.
# STROMA_RAY_HOST=ray-head

# Ray dashboard port (optional; bind to localhost only for security).
STROMA_RAY_DASHBOARD_PORT=8265

# Internal shared API secret for vLLM --api-key and OOD client injection.
# Generate with: openssl rand -hex 32
# Both the server (stroma-ai-vllm.service) and clients (OOD script.sh.erb)
# must use the EXACT same value, or all requests return HTTP 401.
STROMA_API_KEY=CHANGEME_generate_with_openssl_rand_hex_32


# =============================================================================
# MODEL
# =============================================================================

# Absolute path to model weights on the shared filesystem.
# This path must be identical on the Proxmox VM AND all Slurm worker nodes.
# Default: ${STROMA_SHARED_ROOT}/models/Qwen2.5-Coder-32B-Instruct-AWQ
STROMA_MODEL_PATH=/share/models/Qwen2.5-Coder-32B-Instruct-AWQ

# Model name served via the API (/v1/models endpoint).
# Kilo Code and OOD clients reference this name when making requests.
STROMA_MODEL_NAME=stroma-ai-coder


# =============================================================================
# CONTAINER
# =============================================================================

# Path to the built Apptainer/Singularity .sif image on shared storage.
# Must be pre-built and copied here before starting workers.
# See: deploy/containers/stroma-ai-vllm.def
# Default: ${STROMA_SHARED_ROOT}/containers/stroma-ai-vllm.sif
STROMA_CONTAINER=/share/containers/stroma-ai-vllm.sif

# Container command override. Auto-detected if unset.
# Set explicitly if both apptainer and singularity are installed.
# CONTAINER_CMD=apptainer

# GPU binding flag for Apptainer.
# Use --nv for older Apptainer/Singularity or --nvccli for Apptainer 1.3+
# with CDI device enumeration. Default is --nv (broadest compatibility).
# STROMA_CONTAINER_GPU_FLAG=--nv


# =============================================================================
# SLURM
# =============================================================================

# Slurm partition reserved for StromaAI burst workers.
# Create with: scontrol create partition Name=stroma-ai-gpu ...
# Directory containing Slurm binaries (sbatch, squeue, scancel).
# Required when Slurm is installed outside systemd's default PATH.
# Find it with:  dirname $(which sbatch)
STROMA_SLURM_BIN_DIR=/cm/shared/apps/slurm/current/bin

STROMA_SLURM_PARTITION=stroma-ai-gpu

# Slurm account for burst job billing.
# Create with: sacctmgr add account stroma-ai-service
STROMA_SLURM_ACCOUNT=stroma-ai-service

# Absolute path to the Slurm worker sbatch script on shared storage.
# Default: ${STROMA_SHARED_ROOT}/slurm/stroma_ai_worker.slurm
STROMA_SLURM_SCRIPT=/share/slurm/stroma_ai_worker.slurm

# Slurm walltime for burst jobs (D-HH:MM:SS or HH:MM:SS format).
# CRITICAL: Must be BELOW your user's QOS MaxWall limit (not just partition limit).
# Use scripts/check-slurm-limits.sh to check your limits.
# Watcher re-submits before expiry if a job is still needed.
# Safe default: 12:00:00 (fits 'normal' QOS). Increase if assigned higher QOS.
STROMA_SLURM_WALLTIME=12:00:00

# CPU count to request per burst job (Slurm --cpus-per-task).
# Set to the physical core count of your GPU worker nodes.
# Passed by the Watcher at sbatch submit time; do NOT set in the SBATCH script.
STROMA_SLURM_CPUS=64

# Memory request per burst job (Slurm --mem notation: 900G, 1T, 2000M, etc.).
# Leave ~5–10% headroom from total RAM for OS and filesystem buffer cache.
# Passed by the Watcher at sbatch submit time; do NOT set in the SBATCH script.
STROMA_SLURM_MEM=900G

# Maximum number of concurrent burst worker jobs.
# Conservative default: 5. Controls maximum GPU nodes drawn from cluster.
# Increase after verifying scheduler impact on research workloads.
STROMA_MAX_BURST_WORKERS=5

# (OPTIONAL) Slurm reservation name for an always-warm GPU node.
# When set, the watcher submits the first burst job with --reservation=<name>,
# eliminating cold-start latency by keeping one node pre-allocated.
# Leave unset (commented out) to skip warm-node mode — safe for initial
# deployment. Add after validating burst scaling on your cluster.
#
# Requirements for the reservation:
#   - Target node must be idle at creation time (squeue -w <node>)
#   - Use Flags=MAINT,IGNORE_JOBS,OVERLAP to coexist with maintenance windows
#   - Include TRES=cpu=<cores>,gres/gpu=<count> matching AccountingStorageTRES
#   - See docs/deployment-guide.md §1.5 for the full scontrol create command
#
# STROMA_WARM_RESERVATION=stroma-ai-warm

# NUMA node to bind burst workers to (numactl --cpunodebind= --membind=).
# Set to the NUMA node closest to the GPU (usually 0 on single-socket nodes).
# On dual-socket nodes, run `numactl --hardware` on a worker to identify the
# correct node for your GPU. Leave unset to skip NUMA binding (safe default).
# STROMA_NUMA_BIND=0


# =============================================================================
# vLLM TUNING
# =============================================================================

# vLLM quantization method. Must match the model weights format.
# Common values: awq (AWQ-quantized), fp8 (FP8-native), gptq (GPTQ).
# Use empty string (unset) for unquantized models.
STROMA_VLLM_QUANTIZATION=awq

# KV cache data type.
#   auto — let vLLM choose based on the detected GPU (safe for all hardware)
#   fp8  — explicit FP8; only supported on Ada Lovelace (CC ≥ 8.9) and Hopper
#          GPUs (e.g., L40, L40S, H100, H200). Will error on Ampere (A30, A100),
#          Volta (V100), and any older architecture.
# Leave as auto unless you have confirmed Ada Lovelace or Hopper hardware.
STROMA_KV_CACHE_DTYPE=auto

# Fraction of GPU VRAM used for the KV cache (0.0–1.0).
# 0.85 leaves ~15% headroom for the CUDA runtime and page tables.
# Example: A30 24GB × 0.85 = ~20.4GB usable for model weights + KV cache.
# Qwen2.5-Coder-32B-Instruct-AWQ uses ~18.5GB weights, leaving ~1.9GB on-GPU KV.
STROMA_GPU_MEM_UTIL=0.85

# CPU KV cache overflow in GB. Exploits large CPU RAM on HPC nodes to serve
# far more concurrent sequences than GPU VRAM alone permits.
# Tune down if worker nodes run other workloads alongside the GPU job.
STROMA_CPU_OFFLOAD_GB=200

# Maximum sequence length (tokens). Tune based on available KV cache budget.
# With 24GB VRAM × 0.85, AWQ weights at ~18.5GB, and fp16 KV: ~1.9GB = ~32K tokens.
# Increase if users need very long code context; decrease to reduce VRAM pressure.
STROMA_MAX_MODEL_LEN=32768

# Maximum concurrent request sequences. Size for peak load (1–15 users).
# Each sequence holds one active generation slot; excess queues.
STROMA_MAX_NUM_SEQS=64

# Number of CPU threads for KV cache management. Set to ~half the node's CPUs.
STROMA_VLLM_CPU_KV_THREADS=32

# Slurm GRES string for the GPU resource request (--gres= argument to sbatch).
#
# When set, the Watcher passes --gres=<value> to sbatch and does NOT use
# --gpus-per-node, so you can be explicit about GPU type and quantity.
# When unset, the Watcher falls back to --gpus-per-node=1 (works for single-
# type partitions but may allocate MIG slices unexpectedly on mixed nodes).
#
# Examples:
#   Full GPU, any type in partition:  STROMA_SLURM_GRES=gpu:1
#   Full A30:                         STROMA_SLURM_GRES=gpu:a30:1
#   Two full A100s:                   STROMA_SLURM_GRES=gpu:a100:2
#   One MIG 3g.20gb slice (A100):     STROMA_SLURM_GRES=gpu:3g.20gb:1
#   One MIG 2g.12gb slice (A30 MIG):  STROMA_SLURM_GRES=gpu:2g.12gb:1
#   Mixed: 1 A30 + 2 MIG 2g.12gb:    STROMA_SLURM_GRES=gpu:a30:1,gpu:2g.12gb:2
#
# To see available GRES on your cluster:  sinfo -o "%N %G"
# To list configured MIG profiles:        scontrol show config | grep -i gres
#
# IMPORTANT: Set STROMA_GPUS_PER_NODE below to match the number of logical
# GPU devices this GRES string allocates (Ray uses this count for scheduling).
# For MIG: each slice counts as 1 logical GPU.  For multi-GPU: set to the
# total number of GPUs in the GRES string (e.g., 4 for gpu:a100:4).
#
# Leave unset on simple single-type-GPU clusters with no MIG.
# STROMA_SLURM_GRES=gpu:a30:1

# Number of logical GPUs per burst worker node advertised to Ray.
# Must match the number of GPU devices the STROMA_SLURM_GRES string allocates.
# For full GPUs: set to the count (e.g., 4 for quad-A100 nodes).
# For MIG slices: set to the number of slices (each slice = 1 logical GPU).
# When using --gpus-per-node fallback (STROMA_SLURM_GRES unset): set to 1.
STROMA_GPUS_PER_NODE=1


# =============================================================================
# WATCHER SCALING
# =============================================================================

# Polling interval (seconds) for metrics and state transitions.
STROMA_WATCHER_POLL_INTERVAL=30

# Number of waiting requests that triggers a scale-up submission.
# Tune down for faster response; tune up to avoid thrashing.
STROMA_SCALE_UP_THRESHOLD=2

# Seconds with zero requests before idle scale-down fires.
# 300s = 5 minutes. Balances GPU cost vs. cold-start penalty.
STROMA_SCALE_DOWN_IDLE_SECONDS=300

# Seconds between scale-up submissions (prevents burst storm).
# A burst of 15 simultaneous users should not trigger 15 sbatch calls.
STROMA_SCALE_UP_COOLDOWN=300

# Absolute path to watcher persistent state file.
# Watcher reads this on startup to recover tracked jobs after a restart.
STROMA_STATE_FILE=/opt/stroma-ai/watcher_state.json

# Slurm worker sbatch script path (used by watcher when submitting burst jobs).
# Duplicated here so the watcher service doesn't need a separate config.
# STROMA_SLURM_SCRIPT set above under SLURM section also covers this.


# =============================================================================
# LOGGING
# =============================================================================

# Directory for Slurm burst worker stdout/stderr logs.
# Must be writable from Slurm compute nodes (i.e., on shared storage).
# Default: ${STROMA_INSTALL_DIR}/logs
STROMA_LOG_DIR=${STROMA_INSTALL_DIR}/logs


# =============================================================================
# IDENTITY & AUTHENTICATION  (Keycloak / OIDC)
# =============================================================================
# Set by deploy/keycloak/setup-keycloak.sh.
# For LOCAL deployments these are populated automatically.
# For EXTERNAL deployments fill in your institutional IdP values.

# OIDC discovery URL — the .well-known/openid-configuration endpoint of your IdP.
# Examples:
#   Keycloak (local) : http://localhost:8080/realms/stroma-ai/.well-known/openid-configuration
#   Okta             : https://your-org.okta.com/oauth2/default/.well-known/openid-configuration
#   Azure AD         : https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
OIDC_DISCOVERY_URL=

# Canonical issuer claim (iss) expected in all JWTs. Auto-derived from the
# discovery document if left empty; set explicitly for extra validation.
OIDC_ISSUER=

# JWT audience claim expected by the FastAPI gateway (must match the
# stroma-gateway client configuration in Keycloak).
OIDC_AUDIENCE=stroma-gateway

# Realm role that grants access to inference endpoints.
GATEWAY_ALLOWED_ROLE=stroma_researcher

# Keycloak admin API base URL (used by stroma-cli for realm management).
# Empty for external IdPs.
# For dev: http://localhost:8080
# For prod with nginx TLS: https://your-fqdn
KC_ADMIN_URL=

# Internal URL nginx uses to reach Keycloak backend.
# For same-host: http://127.0.0.1:8080
# For remote host: http://keycloak-host.example:8080
KC_INTERNAL_URL=http://127.0.0.1:8080

# Keycloak client credentials for the FastAPI gateway.
# Generated by setup-keycloak.sh for LOCAL mode, or provided by your IdP admin.
KC_GATEWAY_CLIENT_ID=stroma-gateway
KC_GATEWAY_CLIENT_SECRET=CHANGEME_generate_with_openssl_rand_hex_32

# Keycloak client credentials for OpenWebUI OIDC login.
KC_OPENWEBUI_CLIENT_ID=openwebui
KC_OPENWEBUI_CLIENT_SECRET=CHANGEME_generate_with_openssl_rand_hex_32

# JWKS cache TTL in seconds. The gateway re-fetches signing keys from the IdP
# after this interval. 3600 (1 hour) is a safe default.
JWKS_REFRESH_SECS=3600


# =============================================================================
# SECURE GATEWAY  (src/gateway.py)
# =============================================================================

# URL the FastAPI gateway listens on. Used by OpenWebUI and Kilo Code clients.
# In production, put nginx in front and expose via HTTPS on port 443.
STROMA_GATEWAY_URL=http://localhost:9000

# Port the FastAPI gateway process binds on.
GATEWAY_PORT=9000

# Log level for the gateway uvicorn process (debug|info|warning|error).
GATEWAY_LOG_LEVEL=info

# Internal URL the gateway uses to reach the vLLM backend.
# This is the *internal* connection (not exposed publicly).
# Default matches STROMA_VLLM_PORT from the HEAD NODE section above.
VLLM_BACKEND_URL=http://localhost:8000

# Override the JWKS URI from OIDC discovery.
# Required when Keycloak sits behind a self-signed TLS proxy: the JWKS URI
# in the discovery doc will point at the HTTPS proxy URL, which PyJWT's
# PyJWKClient cannot verify. Set this to the direct internal HTTP URL instead:
#   JWKS_OVERRIDE_URI=http://10.14.193.207:8080/realms/stroma-ai/protocol/openid-connect/certs
JWKS_OVERRIDE_URI=

# Set to "false" to skip TLS certificate verification when fetching the OIDC
# discovery document. Only needed if OIDC_DISCOVERY_URL is HTTPS with a
# self-signed cert. Prefer JWKS_OVERRIDE_URI + plain HTTP instead.
GATEWAY_VERIFY_SSL=true


# =============================================================================
# OPENWEBUI
# =============================================================================

# URL of the OpenWe

# Internal URL nginx uses to reach OpenWebUI backend.
# For same-host: http://127.0.0.1:3000
# For remote host: http://openwebui-host.example:3000
OPENWEBUI_INTERNAL_URL=http://127.0.0.1:3000
# URL of the external OpenWebUI instance (set by deploy/openwebui/setup-openwebui.sh).
# Used by stroma-cli status and other tooling.
OPENWEBUI_URL=

# Host port for the OpenWebUI container (if running locally).
OPENWEBUI_PORT=3000

# Session signing secret for OpenWebUI. Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGEME_generate_with_openssl_rand_hex_32

# Display name shown in the OpenWebUI browser tab and login page.
WEBUI_NAME=StromaAI Research Chat

# Whether new users can self-register via SSO (true/false).
ENABLE_OAUTH_SIGNUP=true

# Optional path prefix when serving OpenWebUI behind a reverse proxy sub-path.
# Example: set to "/chat" (no trailing slash) when proxied at https://ood-host/chat/
# Leave unset (empty) when serving at the root path (http://host:3000/).
WEBUI_BASE_URL=


# =============================================================================
# TLS / nginx
# =============================================================================

# TLS certificate and key paths on the Proxmox VM.
# For self-signed (air-gapped default):
#   openssl req -x509 -nodes -days 3650 -newkey rsa:4096 \
#     -keyout /etc/ssl/stroma-ai/server.key \
#     -out /etc/ssl/stroma-ai/server.crt \
#     -subj "/CN=${STROMA_HEAD_HOST}"
# For internal CA: request cert from your PKI and place here.
STROMA_TLS_CERT=/etc/ssl/stroma-ai/server.crt
STROMA_TLS_KEY=/etc/ssl/stroma-ai/server.key


# =============================================================================
# OOD INTEGRATION
# =============================================================================

# Path to the OOD config file sourced by script.sh.erb.
# Place a stripped-down copy of config.env here with only the keys
# needed by OOD (HEAD_HOST, HTTPS_PORT, API_KEY, MODEL_NAME).
STROMA_OOD_CONF=/etc/ood/stroma-ai.conf


# =============================================================================
# ACTIVE DIRECTORY / LDAP FEDERATION  (optional)
# =============================================================================
# Populated by deploy/keycloak/setup-ad.sh.
# When set, Keycloak federates users from your institution's Active Directory
# so researchers log in with their normal network credentials.
#
# Run the setup wizard:
#   cd /opt/stroma-ai && deploy/keycloak/setup-ad.sh
#
# Security notes:
#   - AD_BIND_DN should be a READ-ONLY service account (no write permissions)
#   - Use ldaps:// (TLS port 636) in production; ldap:// (port 389) for testing only
#   - AD_BIND_PASSWORD is stored here (config.env is chmod 640)

# LDAP/AD server URL.
# Examples:
#   ldaps://ad.moffitt.org           (Active Directory, TLS — recommended)
#   ldaps://ad.moffitt.org:636       (explicit TLS port)
#   ldap://ad.moffitt.org:389        (plain-text — testing only)
AD_SERVER_URL=

# Distinguished Name of the read-only service account used to bind to AD.
# Example: cn=svc-stroma,ou=Service Accounts,dc=moffitt,dc=org
AD_BIND_DN=

# Password for the service account above.
AD_BIND_PASSWORD=

# Base DN under which all user accounts reside.
# Example: ou=Users,dc=moffitt,dc=org
AD_USER_DN=

# Full DN of the AD security group whose members receive the stroma_researcher
# role in Keycloak (i.e., permission to use the StromaAI API).
# Example: CN=HPC-GPU-Users,ou=Groups,dc=moffitt,dc=org
AD_RESEARCHER_GROUP=

# ---------------------------------------------------------------------------
# Advanced AD tuning — safe defaults work for most Active Directory deployments
# ---------------------------------------------------------------------------

# LDAP object class for user accounts. AD default: user (not inetOrgPerson)
AD_USER_OBJECT_CLASS=user

# Attribute used as the unique identifier (binary in AD, string in OpenLDAP).
# AD: objectGUID   OpenLDAP: entryUUID
AD_UUID_ATTR=objectGUID

# Attribute mapped to Keycloak username.
# AD: sAMAccountName   OpenLDAP/RFC2307: uid
AD_USERNAME_ATTR=sAMAccountName

# Standard personal attribute mappings (same for AD and OpenLDAP).
AD_FIRSTNAME_ATTR=givenName
AD_LASTNAME_ATTR=sn
AD_EMAIL_ATTR=mail

# LDAP object class for group entries.
# AD: group   OpenLDAP/POSIX: groupOfNames or posixGroup
AD_GROUP_OBJECT_CLASS=group

# Full synchronization interval in seconds (0 = manual sync only).
# 86400 = once per day. Changed-user sync always runs every 3600s.
AD_SYNC_INTERVAL=86400

# Optional LDAP search filter applied to ALL user lookups (in addition to
# objectclass=user and sAMAccountName match).  Use this to restrict which AD
# users Keycloak can authenticate — e.g. require membership in one or more groups.
# Leave blank to allow all users found under AD_USER_DN.
# Example (memberOf any of three groups):
#   AD_CUSTOM_FILTER=(|(memberOf=CN=HPC Users,OU=DLs,...)(memberOf=CN=Admins,OU=DLs,...))
AD_CUSTOM_FILTER=

# ---------------------------------------------------------------------------
# LDAPS / TLS trust for Active Directory
# ---------------------------------------------------------------------------
# When AD_SERVER_URL uses ldaps://, Keycloak's JVM must trust the AD server's
# TLS certificate.  On RHEL/Rocky the host Java truststore at the path below
# is maintained by `update-ca-trust` and typically already contains the
# enterprise PKI chain.  Mount it into the Keycloak container (see
# deploy/keycloak/docker-compose.yml) so Keycloak can validate the AD cert.
#
# Override KC_LDAP_TRUSTSTORE_JKS if your CA cert is in a custom JKS file.
# Override KC_LDAP_TRUSTSTORE_PASSWORD if the JKS password isn't "changeit".
KC_LDAP_TRUSTSTORE_JKS=/etc/pki/java/cacerts
KC_LDAP_TRUSTSTORE_PASSWORD=changeit
