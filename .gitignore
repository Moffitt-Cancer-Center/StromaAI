# StromaAI — .gitignore
# =============================================================================
# Never commit secrets or site-specific config to version control.
# All site-specific values belong in config.env (not config.example.env).
# =============================================================================

# Cruft staging area (temporary holding directory, not tracked)
cruft/

# Reusable project template (move to its own repo when ready)
dev_template/

# Source brainstorm / working notes (not part of the public repo)
.bg-shell/
.github/prompts/
kilo_gsd.build
kilo_update.patch

# Local config files (contain secrets — never commit)
config/config.env
config.env
/opt/stroma-ai/config.env
/etc/ood/stroma-ai.conf
deploy/keycloak/.env
deploy/keycloak/realm-import.json
deploy/head/.env
deploy/head/nginx.conf
deploy/openwebui/.env

# Backup files (contain secrets from original .env files)
**/.env.bak.*

# Dev environment secrets and generated files (dev/dev.sh writes these)
dev/.env
dev/dev-data/certs/
dev/dev-data/realm/

# dev-data directories: keep the tree but not the contents
# (model weights are large; logs/state are ephemeral)
dev/dev-data/models/*
dev/dev-data/shared/logs/*
!dev/dev-data/models/.gitkeep
!dev/dev-data/shared/logs/.gitkeep

# Built Apptainer images (binary, large — store on shared storage instead)
*.sif
*.simg

# Watcher runtime state (ephemeral — not part of repo)
**/watcher_state.json
**/watcher_state.json.tmp

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# Editor and OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/
*.orig

# Node (if any web tooling is added later)
node_modules/

# Logs
*.log
logs/

# Certificates (site-specific)
*.crt
*.key
*.pem

# Java keystores / truststores (site-specific, may contain private certs)
*.jks
*.p12
*.pfx

# Runtime state and generated data (ephemeral — not part of repo)
state/
client.env
config.env.bak.*

# Python virtual environment
venv/
.venv/

# HPC / cluster user dotfiles and caches (appear when repo is cloned into $HOME)
.apptainer/
.bash_history
.bash_logout
.bash_profile
.bashrc
.cache/
.cm/
.config/
.emacs
.esd_auth
.kshrc
.lmod.d/
.local/
.mozilla/
.nv/
.ssh/
.vim/
.viminfo
