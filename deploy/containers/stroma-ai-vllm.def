# =============================================================================
# StromaAI — Apptainer Container Definition
# =============================================================================
# Builds a single portable container image used by ALL components:
#   • Slurm burst workers (RHEL/Rocky/AlmaLinux nodes) — GPU inference
#   • Proxmox VM (Debian) — Ray client tools (if not running bare venv)
#
# Build instructions:
#   # On an internet-connected machine with Apptainer installed:
#   apptainer build stroma-ai-vllm.sif stroma-ai-vllm.def
#
#   # Copy to shared storage:
#   rsync -avz stroma-ai-vllm.sif cluster:/share/containers/
#
# RHEL / SELinux notes:
#   Before running on RHEL Slurm nodes, ensure:
#     setsebool -P container_use_cgroups 1
#     setsebool -P container_manage_cgroup 1
#   If using Apptainer 1.3+ with CDI, prefer --nvccli over --nv.
#   See docs/rhel-slurm-setup.md for the full RHEL pre-flight checklist.
#
# Version pinning:
#   ALL versions below are explicit — no implicit "latest" anywhere.
#   When upgrading, update ALL four version variables together and retest
#   on RHEL before updating stroma-ai-vllm.sif on shared storage.
#
# Tested with:
#   CUDA  12.6 (nvcr.io/nvidia/pytorch:24.10-py3)
#   vLLM  0.7.3
#   Ray   2.40.0
#   A30   24GB VRAM, CUDA compute capability 8.0 (Ampere)
# =============================================================================

Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.10-py3
# ^^ Pin by tag; for maximum reproducibility pin by digest:
# From: nvcr.io/nvidia/pytorch@sha256:<digest>
# Get digest: docker pull nvcr.io/nvidia/pytorch:24.10-py3 && docker inspect

%labels
    org.opencontainers.image.title       stroma-ai-vllm
    org.opencontainers.image.description "vLLM + Ray worker for StromaAI HPC burst inference"
    org.opencontainers.image.licenses    Apache-2.0
    stroma-ai.vllm-version                 0.7.2
    stroma-ai.ray-version                  2.40.0
    stroma-ai.cuda-base                    nvcr.io/nvidia/pytorch:24.10-py3
    stroma-ai.tested-gpu                   NVIDIA A30 (Ampere, CC 8.0)

%environment
    # Prevent any attempt to reach the internet at runtime (air-gapped)
    export HF_HUB_OFFLINE=1
    export TRANSFORMERS_OFFLINE=1
    export HF_DATASETS_OFFLINE=1

    # vLLM / Ray tuning
    export VLLM_CPU_KV_CACHE_THREADS=32
    export RAY_DEDUP_LOGS=0
    export RAY_DISABLE_IMPORT_WARNING=1
    export NCCL_DEBUG=WARN

    # Python buffering (ensures logs appear in Slurm output files immediately)
    export PYTHONUNBUFFERED=1

    # Silence tokenizer parallelism warning inside Ray workers
    export TOKENIZERS_PARALLELISM=false

%post
    set -eu

    # -------------------------------------------------------------------------
    # System dependencies needed for NCCL / vLLM build artifacts
    # The NGC pytorch base already includes CUDA, cuDNN, NCCL, and torch.
    # We install additional OS-level deps here.
    # -------------------------------------------------------------------------
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        wget curl git ca-certificates \
        libssl-dev libffi-dev \
        numactl \
        2>/dev/null
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # -------------------------------------------------------------------------
    # Upgrade pip
    # -------------------------------------------------------------------------
    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel

    # -------------------------------------------------------------------------
    # Core packages — ALL pinned to exact versions
    # Test compatibility before bumping ANY version:
    #   vLLM and Ray must be upgraded together (they share Pydantic + gRPC deps)
    # NOTE: vLLM 0.7.3 introduced DeepseekVLV2Config which uses a Python 3.11+
    #   dataclass pattern — it crashes on Python 3.10 (NGC 24.10-py3 base).
    #   Stay on 0.7.2 until the base image is upgraded to a Python 3.11 build.
    # -------------------------------------------------------------------------
    python3 -m pip install --no-cache-dir \
        "vllm==0.7.2" \
        "ray[serve]==2.40.0" \
        "requests==2.32.3" \
        "pyyaml==6.0.2" \
        "aiohttp==3.11.9" \
        "openai==1.65.0"

    # -------------------------------------------------------------------------
    # Sanity checks at build time
    # -------------------------------------------------------------------------
    python3 -c "
import torch, vllm, ray
print(f'PyTorch  : {torch.__version__}')
print(f'CUDA     : {torch.version.cuda}')
print(f'vLLM     : {vllm.__version__}')
print(f'Ray      : {ray.__version__}')
# Note: CUDA availability cannot be verified at build time (no GPU in builder)
print('Build-time import check: PASS')
"

%test
    # Run by: apptainer test stroma-ai-vllm.sif
    python3 -c "
import vllm, ray, torch, requests
print('Container self-test: PASS')
print(f'  vLLM  {vllm.__version__}')
print(f'  Ray   {ray.__version__}')
print(f'  Torch {torch.__version__}')
"

%runscript
    # Default entrypoint — override with `apptainer exec` in practice
    echo "StromaAI vLLM container"
    echo "Usage:"
    echo "  Ray worker:  apptainer exec --nv stroma-ai-vllm.sif ray start --address=HEAD:6380 --num-gpus=1 --block"
    echo "  vLLM server: apptainer exec --nv stroma-ai-vllm.sif vllm serve MODEL_PATH [options]"
    echo "  Shell:       apptainer shell --nv stroma-ai-vllm.sif"
