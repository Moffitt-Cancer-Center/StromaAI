# =============================================================================
# StromaAI — logrotate configuration
# =============================================================================
# Rotates Slurm burst worker output logs on shared storage.
#
# Install:
#   cp deploy/logrotate/stroma-ai /etc/logrotate.d/stroma-ai
#
# Test (dry-run):
#   logrotate --debug /etc/logrotate.d/stroma-ai
#
# Note: STROMA_LOG_DIR from config.env defaults to /share/logs/stroma-ai.
# Update the paths below if your site uses a different log directory.
# =============================================================================

/share/logs/stroma-ai/*.out
/share/logs/stroma-ai/*.err {
    # Rotate daily; keep 30 days of history
    daily
    rotate 30

    # Compress rotated files (delayed one cycle to allow ongoing writes)
    compress
    delaycompress

    # Do nothing if the log file is empty or missing
    missingok
    notifempty

    # Rotate by copying and zeroing — safe for Slurm jobs that may still
    # be writing to their output file. Does not require signalling the writer.
    copytruncate

    # Run pre/postrotate scripts once even when multiple files match
    sharedscripts
}
