[Unit]
Description=StromaAI — vLLM Watcher (Dynamic Slurm Burst Scaling)
Documentation=https://github.com/your-org/stroma-ai
After=network-online.target stroma-ai-vllm.service
Wants=network-online.target
Requires=stroma-ai-vllm.service

[Service]
Type=simple
User=aiflux
Group=aiflux
WorkingDirectory=/opt/stroma-ai

# Sources all STROMA_* environment variables.
EnvironmentFile=/opt/stroma-ai/config.env

# Python is installed by install.sh into /opt/stroma-ai/venv.
ExecStart=/opt/stroma-ai/venv/bin/python3 /opt/stroma-ai/src/vllm_watcher.py

# Restart=always — the Watcher should always be running; failures are
# usually transient (Slurm CLI timeout, Ray connection flap).
Restart=always
RestartSec=10s
TimeoutStartSec=30s
TimeoutStopSec=30s

# Journal logging — view with: journalctl -u stroma-ai-watcher -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=stroma-ai-watcher

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/stroma-ai /tmp
PrivateTmp=true
ProtectKernelTunables=true
ProtectControlGroups=true
ProtectHostname=true
RestrictSUIDSGID=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

[Install]
WantedBy=multi-user.target
