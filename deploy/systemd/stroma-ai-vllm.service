[Unit]
Description=StromaAI — vLLM Inference API Server
Documentation=https://github.com/Moffitt-Cancer-Center/StromaAI
After=network-online.target ray-head.service
Wants=network-online.target
Requires=ray-head.service

[Service]
Type=simple
User=stromaai
Group=stromaai
WorkingDirectory=/opt/stroma-ai

# Sources all STROMA_* environment variables.
EnvironmentFile=/opt/stroma-ai/config.env

# vLLM CPU KV cache threads — set before vllm process starts.
# Matches the value baked into the container %environment but can be
# overridden here without rebuilding the image.
Environment=VLLM_CPU_KV_CACHE_THREADS=${STROMA_VLLM_CPU_KV_THREADS}

# Air-gapped: prevent any HuggingFace Hub download attempts at runtime.
Environment=HF_HUB_OFFLINE=1
Environment=TRANSFORMERS_OFFLINE=1

# ---------------------------------------------------------------------------
# IPv6-disabled host workaround (RHEL/Rocky with net.ipv6.conf.all.disable_ipv6=1)
#
# vLLM always initialises a PyTorch distributed world group (even with
# tensor_parallel_size=1) using a TCP rendezvous URL built from get_ip().
# On RHEL nodes where IPv6 is kernel-disabled, gloo's socket creation fails
# with "Address family not supported by protocol" because:
#   1. get_ip() returns the hostname by default
#   2. Linux resolves the hostname to an IPv6 address first
#   3. gloo tries socket(AF_INET6, ...) → fails → engine crash
#
# VLLM_HOST_IP=127.0.0.1 forces get_ip() to return an explicit IPv4 address
# so the rendezvous URL becomes tcp://127.0.0.1:<port>, bypassing IPv6 entirely.
#
# NOTE: Do NOT set GLOO_SOCKET_IFNAME=lo — gloo iterates ALL addresses on the
# 'lo' interface, including ::1 (loopback IPv6 persists even when
# net.ipv6.conf.all.disable_ipv6=1 because loopback is exempt). Without
# GLOO_SOCKET_IFNAME, gloo auto-detects and skips loopback interfaces entirely,
# finding a valid non-loopback IPv4 interface instead.
#
# NCCL_SOCKET_IFNAME=lo is kept for the head-node vLLM (single GPU, no
# inter-node NCCL traffic). Burst workers on Slurm use their own environment.
# ---------------------------------------------------------------------------
Environment=VLLM_HOST_IP=127.0.0.1
Environment=NCCL_SOCKET_IFNAME=lo

# ---------------------------------------------------------------------------
# vLLM serve command
#
# Key flags and their rationale:
#   --quantization awq          — model is AWQ-quantized; reduces VRAM footprint
#   --tensor-parallel-size 1    — one GPU per node; scaling is data-parallel
#   --distributed-executor-backend ray — dispatch GPU workers as Ray actors so
#                                 the head node (no GPU) acts as coordinator;
#                                 replaces the removed --worker-use-ray flag
#   --cpu-offload-gb            — overflow KV cache to CPU RAM; critical for
#                                 high concurrency with long contexts on HPC nodes
#   --kv-cache-dtype auto       — vLLM detects optimal dtype for the GPU;
#                                 auto = fp8 on Ada Lovelace/Hopper, fp16 elsewhere
#   --max-model-len             — token window; tune based on available KV budget
#   --max-num-seqs 64           — concurrent sequence slots; tune for expected load
#   --gpu-memory-utilization    — fraction of VRAM used for model + KV cache
#   -O2                         — piecewise CUDA graphs; best throughput on modern
#                                 NVIDIA GPUs (Volta, Ampere, Ada, Hopper).
#                                 NOTE: mutually exclusive with --enforce-eager
#   --host 0.0.0.0              — nginx on the same host proxies; 0.0.0.0 is safe
#   --trust-remote-code         — required by AWQ model tokenizer; review any
#                                 model update against the upstream repo
#
# --block-size is intentionally omitted so vLLM auto-selects the optimal paged
# attention block size for the detected GPU. Add it explicitly (e.g., 16 or 32)
# if you need to pin the value for a specific architecture.
# ---------------------------------------------------------------------------
# Binaries are installed by install.sh into /opt/stroma-ai/venv.
ExecStart=/opt/stroma-ai/venv/bin/vllm serve \
    ${STROMA_MODEL_PATH} \
    --served-model-name ${STROMA_MODEL_NAME} \
    --quantization ${STROMA_VLLM_QUANTIZATION} \
    --tensor-parallel-size 1 \
    --device cuda \
    --distributed-executor-backend ray \
    --disable-async-output-proc \
    --cpu-offload-gb ${STROMA_CPU_OFFLOAD_GB} \
    --kv-cache-dtype ${STROMA_KV_CACHE_DTYPE} \
    --max-model-len ${STROMA_MAX_MODEL_LEN} \
    --max-num-seqs ${STROMA_MAX_NUM_SEQS} \
    --gpu-memory-utilization ${STROMA_GPU_MEM_UTIL} \
    --enable-chunked-prefill \
    --host 0.0.0.0 \
    --port ${STROMA_VLLM_PORT} \
    --api-key ${STROMA_API_KEY} \
    --trust-remote-code \
    -O2

# Do NOT use Restart=always — an OOM or CUDA error should surface for review.
Restart=on-failure
RestartSec=30s
TimeoutStartSec=300s
TimeoutStopSec=60s

# Give vLLM time to drain in-flight requests before SIGKILL
KillMode=mixed
KillSignal=SIGTERM

StandardOutput=journal
StandardError=journal
SyslogIdentifier=stroma-ai-vllm

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/stroma-ai /tmp /share
PrivateTmp=true
ProtectKernelTunables=true
ProtectControlGroups=true
# ProtectHostname requires systemd >= 243 (RHEL 8 ships 239 — omitted)
RestrictSUIDSGID=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

[Install]
WantedBy=multi-user.target
