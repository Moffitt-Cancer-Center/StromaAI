[Unit]
Description=AI_Flux — Ray Head Node
Documentation=https://github.com/your-org/ai-flux
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=aiflux
Group=aiflux
WorkingDirectory=/opt/ai-flux

# Sources all AI_FLUX_* environment variables from config.env.
# Permissions: chmod 640, chown aiflux:aiflux
EnvironmentFile=/opt/ai-flux/config.env

# Ray head starts with --num-cpus=0 --num-gpus=0 so the Proxmox VM
# (which has no GPU) does not accidentally attract inference work.
# Workers join separately via Slurm sbatch.
#
# Binaries are installed by install.sh into /opt/ai-flux/venv.
ExecStart=/opt/ai-flux/venv/bin/ray start \
    --head \
    --port=${AI_FLUX_RAY_PORT} \
    --dashboard-port=${AI_FLUX_RAY_DASHBOARD_PORT} \
    --dashboard-host=127.0.0.1 \
    --num-cpus=0 \
    --num-gpus=0 \
    --block

ExecStop=/opt/ai-flux/venv/bin/ray stop

Restart=on-failure
RestartSec=15s
TimeoutStartSec=60s
TimeoutStopSec=30s

# Journal logging — view with: journalctl -u ai-flux-ray -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ai-flux-ray

# Security hardening (Debian/systemd 245+)
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/ai-flux /tmp
PrivateTmp=true
ProtectKernelTunables=true
ProtectControlGroups=true
ProtectHostname=true
RestrictSUIDSGID=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

[Install]
WantedBy=multi-user.target
