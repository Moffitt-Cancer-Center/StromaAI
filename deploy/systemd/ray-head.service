[Unit]
Description=StromaAI — Ray Head Node
Documentation=https://github.com/Moffitt-Cancer-Center/StromaAI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=stromaai
Group=stromaai
WorkingDirectory=/opt/stroma-ai

# Sources all STROMA_* environment variables from config.env.
# Permissions: chmod 640, chown stromaai:stromaai
EnvironmentFile=/opt/stroma-ai/config.env

# Ray head starts with --num-cpus=0 --num-gpus=0 so the Proxmox VM
# (which has no GPU) does not accidentally attract inference work.
# Workers join separately via Slurm sbatch.
#
# Binaries are installed by install.sh into /opt/stroma-ai/venv.
ExecStart=/opt/stroma-ai/venv/bin/ray start \
    --head \
    --port=${STROMA_RAY_PORT} \
    --dashboard-port=${STROMA_RAY_DASHBOARD_PORT} \
    --dashboard-host=127.0.0.1 \
    --num-cpus=0 \
    --num-gpus=0 \
    --block

ExecStop=/opt/stroma-ai/venv/bin/ray stop

Restart=on-failure
RestartSec=15s
TimeoutStartSec=60s
TimeoutStopSec=30s

# Journal logging — view with: journalctl -u stroma-ai-ray -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=stroma-ai-ray

# Security hardening
# Note: ProtectKernelTunables and ProtectControlGroups are intentionally omitted —
# Ray reads /proc and manages its own cgroup subtree for resource accounting.
# PrivateTmp is omitted so the /tmp/ray socket is visible to other local services.
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/stroma-ai /tmp /var/tmp
# ProtectHostname requires systemd >= 243 (RHEL 8 ships 239 — omitted)
RestrictSUIDSGID=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

[Install]
WantedBy=multi-user.target
